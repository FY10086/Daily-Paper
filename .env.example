SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_account@qq.com
SMTP_PASS=your_smtp_auth_code
SMTP_SENDER=your_account@qq.com

# Optional: if you prefer env override instead of config.llm
