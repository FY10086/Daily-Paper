  "sources": {
    "_doc": "每个来源最多抓取多少篇候选文章。越大越不容易漏，但运行会更慢。",
    "priority": [
      "europe_pmc",
      "crossref"
    ],
    "max_results_per_source": 100
  },
  "time_window": {
    "_doc": "先在 primary_days 范围内找；若一篇都没选到且 allow_fallback=true，则扩展到 fallback_days 再找一次。",
    "primary_days": 90,
    "fallback_days": 1000,
    "allow_fallback": true
  },
  "journals": {
    "_doc": "白名单期刊及其基础分。分值只用于常规排序，不影响随机保底。",
    "whitelist": {
      "cell genomics": 34,
      "nature genetics": 38,
      "nature methods": 37,
      "nature biotechnology": 38,
      "nature communications": 30,
      "genome biology": 33,
      "nucleic acids research": 31,
      "science advances": 32,
      "plos genetics": 18,
      "briefings in bioinformatics": 13,
      "american journal of human genetics": 30
    },
    "default_score": 0,
    "allow_non_whitelist_fallback": false
  },
  "scoring": {
    "_doc": "常规排序时使用的评分参数。若排序阶段选不出论文，可由 fallback_random 保底。",
    "keyword_weight": 12,
    "journal_weight_multiplier": 1,
    "citation_weight": 0.08,
    "max_citation_bonus": 8,
    "freshness_max_bonus": 15
  },
  "fallback_random": {
    "_doc": "常规排序与常规兜底都没有命中时，从本次已抓到但尚未通过严格过滤的候选里，随机挑 1 篇未发送且医学相关的论文。",
